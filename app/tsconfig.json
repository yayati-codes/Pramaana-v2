{
  "compilerOptions": {
    "target": "ES2022",
    // Bundler resolution + skipLibCheck: the sdk's types re-export
    // @pramaana/semaphore → Semaphore v4 .d.ts, which NodeNext rejects
    // (extensionless relative imports — docs/DECISIONS.md).
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "strict": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"]
  },
  "include": ["src"]
}
